{
  "name": "causalworkshop student sandbox",
  "image": "ghcr.io/rocker-org/devcontainer/tidyverse:4.5",
  "features": {
    "ghcr.io/rocker-org/devcontainer-features/quarto-cli:latest": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "quarto.quarto",
        "GitHub.vscode-pull-request-github"
      ],
      "settings": {
        "r.rterm.linux": "/usr/local/bin/R",
        "r.plot.useHttpgd": true,
        "r.bracketedPaste": true,
        "quarto.render.previewType": "external"
      }
    }
  },
  "postCreateCommand": "Rscript .devcontainer/setup.R",
  "remoteUser": "rstudio"
}
